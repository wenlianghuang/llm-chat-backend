{
  "name": "server",
  "version": "0.4.3",
  "dependencies": {
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "tsup": "8.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-import-esm": "^1.2.1",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "prisma": "^6.19.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "build": "tsup ./src/index.ts --format esm --external @prisma/client --external @fastify/swagger --external @fastify/swagger-ui",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "dev": "tsup ./src/index.ts --format esm --external @prisma/client --external @fastify/swagger --external @fastify/swagger-ui --watch --onSuccess \"pnpm run start\"",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "type": "module"
}
