# PostgreSQL
# - Local Node (no Docker DB): localhost:5432
# - Docker Compose DB from host tools: localhost:5434
# - Inside Compose network the server uses host `db` (set in docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/llm_chat?schema=public"

# HTTP server
PORT=3000
HOST=0.0.0.0

# LLM provider: groq (recommended) | nvidia | stub
# Groq free tier is request-generous — good for homework testing.
# Create a key at https://console.groq.com/keys
LLM_PROVIDER=stub
LLM_API_KEY=

# Optional overrides (defaults are set per provider)
# LLM_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=https://api.groq.com/openai/v1

# NVIDIA alternative (assignment suggestion):
# LLM_PROVIDER=nvidia
# LLM_API_KEY=nvapi-...
# LLM_MODEL=meta/llama-3.1-8b-instruct
# Get a key: https://build.nvidia.com/settings/api-keys
